# Supabase — used by the waitlist form (app/api/waitlist/route.ts).
# The publishable (anon) key is safe to expose; row-level security on the
# `waitlist` table governs what it can do (insert only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Canonical site URL (used for OG/Twitter absolute image URLs).
NEXT_PUBLIC_SITE_URL=https://mentorque.app
